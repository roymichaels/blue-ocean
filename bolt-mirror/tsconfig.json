{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@expo/metro-runtime/src/HMRClient": ["./HMRClient.ts"],
      "@expo/metro-runtime/src/HMRClient.ts": ["./HMRClient.ts"]
    },
    "types": ["react", "jest", "node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "app/**/*",
    "assets/**/*",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".expo",
    ".turbo"
  ]
}
