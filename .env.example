# NOTE: Replace placeholder values with your own credentials for local development.
# Admin Configuration
EXPO_PUBLIC_ADMIN_USERNAME=roymichaels

# Matrix Configuration (for future use)
EXPO_PUBLIC_MATRIX_SERVER=https://matrix.org

# App Configuration
EXPO_PUBLIC_APP_NAME=TheCongress
EXPO_PUBLIC_DEBUG_LOGS=false
EXPO_PUBLIC_JWT_SECRET=your_jwt_secret

# Pinata credentials for IPFS uploads
EXPO_PUBLIC_PINATA_API_KEY=YOUR_PINATA_API_KEY
EXPO_PUBLIC_PINATA_SECRET_API_KEY=YOUR_PINATA_SECRET_KEY
EXPO_PUBLIC_PINATA_JWT=YOUR_PINATA_JWT
# Chat Encryption
EXPO_PUBLIC_CHAT_SECRET=changeme
EXPO_PUBLIC_USE_WAKU=false

# Push Notifications
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key

# Tenant Identifier used to load branding from tenant_settings table
EXPO_PUBLIC_TENANT=thecongress
