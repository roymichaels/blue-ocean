{
  "expo": {
    "entryPoint": "./index.js",
    "platforms": ["ios", "android", "web"],
    "name": "blue-ocean",
    "slug": "blue-ocean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"],
    "extra": {
      "router": {
        "appRoot": "app"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
