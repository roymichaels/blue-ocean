{
  "name": "blue-ocean-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 expo start",
    "dev:mock": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 EXPO_PUBLIC_APP_MODE=mock expo start",
    "dev:live": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 EXPO_PUBLIC_APP_MODE=live expo start",
    "android": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 expo run:android",
    "ios": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 expo run:ios",
    "web": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:web": "EXPO_NO_ROUTER=1 EXPO_USE_STATIC_RENDERER=0 EXPO_PUBLIC_APP_MODE=mock EXPO_WEB_BUNDLER=metro expo export --platform web --output-dir dist && node scripts/report-bundle.js dist",
    "bundle:analyze": "node scripts/report-bundle.js dist",
    "clean": "rimraf node_modules .expo dist",
    "ci": "yarn lint && yarn typecheck && yarn test"
  },
  "dependencies": {
    "expo": "54.0.8",
    "preact": "^10.25.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-web": "~0.21.1",
    "react-native-web-lite": "^1.112.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "~29.7.0",
    "babel-preset-expo": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "~29.7.0",
    "jest-expo": "~49.0.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.1.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFilesAfterEnv": [
      "./tests/setup/jestSetup.ts"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts",
      "<rootDir>/tests/**/*.test.tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.jest.json"
        }
      ]
    }
  },
  "packageManager": "yarn@1.22.22",
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all"
  },
  "resolutions": {
    "metro-transform-plugins": "0.82.3"
  }
}
