{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "react",
      "jest",
      "node"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/application/*": [
        "src/application/*"
      ],
      "@/logic/*": [
        "src/logic/*"
      ],
      "@/data/*": [
        "src/data/*"
      ],
      "@/ui/*": [
        "src/ui/*"
      ],
      "@noble/hashes/sha512": [
        "types/@noble/hashes/sha512"
      ],
      "@noble/ed25519": [
        "types/@noble/ed25519/index"
      ],
      "metro-runtime/src/modules/HMRClient": [
        "types/metro-runtime/src/modules/HMRClient"
      ],
      "@expo/metro-runtime/src/HMRClient": [
        "./HMRClient.ts"
      ],
      "@expo/metro-runtime/src/HMRClient.ts": [
        "./HMRClient.ts"
      ]
    },
    "customConditions": [
      "browser"
    ]
  },
  "include": [
    "App.tsx",
    "index.ts",
    "HMRClient.ts",
    "polyfills.native.ts",
    "polyfills.web.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "nativewind-env.d.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "coverage",
    "node_modules",
    "agents",
    "config",
    "constants",
    "contracts",
    "contexts",
    "infra",
    "indexers",
    "lib",
    "relayer",
    "schemas",
    "scripts",
    "tests",
    "types/**/*.ts",
    "utils",
    "web"
  ],
  "extends": "expo/tsconfig.base.json"
}
