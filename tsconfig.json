{
  "compilerOptions": {
    "baseUrl": ".", // ✅ Point to root
    "paths": {
      "@/*": ["./*"] // ✅ Now @/hooks points to ./hooks
    },
    // other options remain the same
    "strict": true,
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["expo", "react", "react-native"],
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "types/wasm.d.ts",
    "types/lucide-react-native.d.ts"
  ],
  "extends": "expo/tsconfig.base"
}
