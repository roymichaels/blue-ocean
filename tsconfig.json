{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "react",
      "jest",
      "node"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@expo/metro-runtime/src/HMRClient": [
        "./HMRClient.ts"
      ],
      "@expo/metro-runtime/src/HMRClient.ts": [
        "./HMRClient.ts"
      ]
    },
    "customConditions": [
      "browser"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "App.tsx",
    "index.ts",
    "HMRClient.ts",
    "polyfills.native.ts",
    "polyfills.web.ts",
    "types/**/*.d.ts"
  ],
  "extends": "expo/tsconfig.base.json"
}
