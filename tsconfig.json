{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "react",
      "jest",
      "node"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": [
        "app/*"
      ],
      "@features/*": [
        "src/features/*"
      ],
      "@ui/*": [
        "src/ui/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@providers/*": [
        "src/providers/*"
      ],
      "@/auth/*": [
        "src/auth/*"
      ],
      "@/features/*": [
        "src/features/*"
      ],
      "@/shared/*": [
        "src/shared/*"
      ],
      "@/ui/*": [
        "src/ui/*"
      ],
      "@/ui": [
        "src/ui/index.ts"
      ],
      "@/layout/*": [
        "src/layout/*"
      ],
      "@/core/*": [
        "src/core/*"
      ],
      "@/services": [
        "src/services/index.ts"
      ],
      "@/services/*": [
        "src/services/*",
        "services/*"
      ],
      "@/billing": [
        "src/billing/index.ts"
      ],
      "@/billing/*": [
        "src/billing/*"
      ],
      "@/utils/*": [
        "src/utils/*",
        "utils/*"
      ],
      "@/providers": [
        "src/providers/index.ts"
      ],
      "@/providers/*": [
        "src/providers/*"
      ],
      "@/schemas/*": [
        "schemas/*"
      ],
      "@/i18n": [
        "src/i18n.ts"
      ],
      "@/*": [
        "./*"
      ],
      "@expo/metro-runtime/src/HMRClient": [
        "./HMRClient.ts"
      ],
      "@expo/metro-runtime/src/HMRClient.ts": [
        "./HMRClient.ts"
      ]
    },
    "customConditions": [
      "browser"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "types/wasm.d.ts",
    "types/lucide-react-native.d.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["tests"],
  "extends": "expo/tsconfig.base.json"
}
