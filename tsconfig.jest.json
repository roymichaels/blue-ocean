{
    "extends":  "./tsconfig.json",
    "compilerOptions":  {
                            "baseUrl":  ".",
                            "types":  [
                                          "jest",
                                          "node"
                                      ],
                            "jsx":  "react-jsx",
                            "paths":  {
                                          "@/application/*":  [
                                                                 "src/application/*"
                                                             ],
                                          "@/logic/*":  [
                                                             "src/logic/*"
                                                         ],
                                          "@/data/*":  [
                                                            "src/data/*"
                                                        ],
                                          "@/ui/*":  [
                                                          "src/ui/*"
                                                      ],
                                          "@noble/hashes/sha512":  [
                                                                       "types/@noble/hashes/sha512"
                                                                   ],
                                          "@noble/ed25519":  [
                                                                "types/@noble/ed25519/index"
                                                            ],
                                          "metro-runtime/src/modules/HMRClient":  [
                                                                                    "types/metro-runtime/src/modules/HMRClient"
                                                                                ]
                                      },
                            "moduleResolution":  "Bundler"
                        },
    "include":  [
                    "App.tsx",
                    "index.ts",
                    "HMRClient.ts",
                    "polyfills.native.ts",
                    "polyfills.web.ts",
                    "src",
                    "types"
                ]
}
