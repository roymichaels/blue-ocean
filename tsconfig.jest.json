{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["jest", "node"],
    "jsx": "react-jsx",
    "paths": {
      "@app/*": ["app/*"],

      "@features/*": ["src/features/*"],
      "@shared/*": ["src/shared/*"],
      "@ui/*": ["src/ui/*"],
      "@providers/*": ["src/providers/*"],

      "@/*": ["*"],

      "@/auth/*": ["src/auth/*"],
      "@/features/*": ["src/features/*"],
      "@/shared/*": ["src/shared/*"],
      "@/ui/*": ["src/ui/*"],
      "@/ui": ["src/ui/index"],
      "@/layout/*": ["src/layout/*"],
      "@/core/*": ["src/core/*"],
      "@/services": ["src/services/index"],
      "@/services/*": ["src/services/*", "services/*"],
      "@/billing": ["src/billing/index"],
      "@/billing/*": ["src/billing/*"],
      "@/utils/*": ["src/utils/*", "utils/*"],
      "@/providers/*": ["src/providers/*"],
      "@/providers": ["src/providers/index"],
      "@/i18n": ["src/i18n"],
      "@/schemas/*": ["schemas/*"],
      "@/constants/*": ["constants/*"],
      "src/*": ["src/*"]
    },
    "moduleResolution": "Bundler"
  },
  "include": [
    "tests",
    "src",
    "services",
    "app",
    "constants",
    "types",
    "scripts",
    "jest.config.js"
  ]
}
